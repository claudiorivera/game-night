{
	"name": "game-night",
	"version": "0.3.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"build": "next build",
		"vercel-build": "pnpm db:push && next build",
		"dev": "next dev",
		"start": "next start",
		"check-types": "tsc --noEmit",
		"check:fix": "biome check --write",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "pnpm with-env tsx src/server/db/run-seed.ts",
		"clean": "rm -rf node_modules .next .turbo",
		"with-env": "dotenvx run --"
	},
	"dependencies": {
		"@daypicker/react": "10.0.1",
		"@faker-js/faker": "10.4.0",
		"@paralleldrive/cuid2": "3.3.0",
		"@t3-oss/env-nextjs": "0.13.11",
		"@tailwindcss/postcss": "4.3.0",
		"@tanstack/react-query": "5.100.14",
		"better-auth": "1.6.11",
		"bgg-xml-api-client": "0.3.2",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"date-fns": "4.3.0",
		"drizzle-orm": "0.45.2",
		"esm-env": "1.2.2",
		"lucide-react": "1.16.0",
		"next": "16.2.6",
		"pg": "8.21.0",
		"postcss": "8.5.15",
		"radix-ui": "1.4.3",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-hot-toast": "2.6.0",
		"server-only": "0.0.1",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "4.3.0",
		"usehooks-ts": "3.1.1",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@dotenvx/dotenvx": "1.69.1",
		"@types/node": "25.9.1",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.15",
		"@types/react-dom": "19.2.3",
		"drizzle-kit": "0.31.10",
		"tsx": "4.22.3",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.3"
	}
